<%- include('partials/header') %>

<!-- Hero Section -->
<section class="hero" style="background-image: linear-gradient(rgba(10, 25, 47, 0.8), rgba(10, 25, 47, 0.8)), url('/images/hero_cargo.png');">
    <div class="container hero-content">
        <h3 class="hero-subtitle">PREMIUM LOGISTICS NETWORK</h3>
        <h1 class="hero-title">Delivering Your Cargo Across the <span class="highlight">Gulf</span></h1>
        <p class="hero-description">The most reliable, secure, and rapid transport solution based in Dubai. Connecting businesses seamlessly from the UAE to Oman, Saudi Arabia, Bahrain, and beyond.</p>
        <div class="hero-cta">
            <a href="/book" class="btn-primary">Book Cargo Now</a>
            <a href="/services" class="btn-secondary">Explore Services</a>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="features section-padding">
    <div class="container">
        <div class="section-title text-center">
            <h2>Why Choose <span class="highlight">Tiger Youth</span></h2>
            <p>We bring unparalleled efficiency and security to your supply chain.</p>
        </div>
        <div class="grid grid-3">
            <div class="feature-card">
                <div class="feature-icon">&#128666;</div>
                <h3>Extensive Gulf Fleet</h3>
                <p>A massive, modern fleet of trucks equipped for heavy cargo, operating daily across multiple GCC borders.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">&#9201;</div>
                <h3>On-Time Delivery</h3>
                <p>Precision logistics ensured through real-time tracking and optimized route management.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">&#128110;</div>
                <h3>Full Cargo Security</h3>
                <p>Premium insurance coverage and strict security protocols from pick-up to your destination port or warehouse.</p>
            </div>
        </div>
    </div>
</section>

<!-- About Preview Section -->
<section class="about-preview section-padding bg-light">
    <div class="container">
        <div class="grid grid-2 align-center">
            <div class="about-content">
                <h4 class="sub-heading">ABOUT OUR COMPANY</h4>
                <h2>Your Trusted Partner in <span class="highlight">Middle East Logistics</span></h2>
                <p>Tiger Youth Transport was established with one goal: to redefine cargo movement in Dubai and the wider Gulf region. We bridge borders with efficiency, ensuring your trade routes remain uninterrupted.</p>
                <ul class="check-list">
                    <li>&#10003; 10+ Years of Regional Experience</li>
                    <li>&#10003; Dedicated Custom Clearance Support</li>
                    <li>&#10003; State-of-the-Art Warehousing</li>
                </ul>
                <a href="/about" class="btn-primary mt-4">Discover More About Us</a>
            </div>
            <div class="about-image-wrapper">
                <img src="/images/fleet_cargo.png" alt="Tiger Youth Transport Fleet" class="radius-image shadow-large img-fluid">
            </div>
        </div>
    </div>
</section>

<!-- Partners / Trusted By Section -->
<section class="partners section-padding bg-light">
    <div class="container text-center">
        <h4 class="sub-heading mb-4">TRUSTED BY LEADING BUSINESSES</h4>
        <div class="partner-logos">
            <div class="partner-logo">GlobalTech Industry</div>
            <div class="partner-logo">UAE Builders Group</div>
            <div class="partner-logo">Gulf Retail Network</div>
            <div class="partner-logo">Saudi Energy Corp</div>
            <div class="partner-logo">Oman Constructors</div>
        </div>
    </div>
</section>

<!-- Testimonials Section -->
<section class="testimonials section-padding">
    <div class="container">
        <div class="section-title text-center">
            <h2>Client <span class="highlight">Testimonials</span></h2>
            <p>Don't just take our word for it—see what our partners say.</p>
        </div>
        <div class="grid grid-3">
            <div class="testimonial-card shadow-large">
                <div class="quote-icon">&ldquo;</div>
                <p class="testimonial-text">"Tiger Youth Transport drastically cut down our transit times to Saudi Arabia. Their customs clearing efficiency is phenomenal."</p>
                <div class="testimonial-author">
                    <h4>Ahmed Al Mansoori</h4>
                    <span>Supply Chain Director, GlobalTech</span>
                </div>
            </div>
            <div class="testimonial-card shadow-large">
                <div class="quote-icon">&ldquo;</div>
                <p class="testimonial-text">"Reliable, communicative, and safe. We trust them with all our high-value retail distribution across the GCC."</p>
                <div class="testimonial-author">
                    <h4>Sarah Jenkins</h4>
                    <span>Operations Manager, Gulf Retail</span>
                </div>
            </div>
            <div class="testimonial-card shadow-large">
                <div class="quote-icon">&ldquo;</div>
                <p class="testimonial-text">"Handling oversized construction cargo is never easy, but their heavy transport team executed it flawlessly without any delays."</p>
                <div class="testimonial-author">
                    <h4>Omar Tariq</h4>
                    <span>CEO, UAE Builders</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Call to Action Banner -->
<section class="cta-banner">
    <div class="container text-center">
        <h2>Ready to Ship Your Goods?</h2>
        <p>Get a fast quote and experience seamless cargo handling today.</p>
        <a href="/contact" class="btn-primary btn-large">Get Free Quote</a>
    </div>
</section>

<%- include('partials/footer') %>
