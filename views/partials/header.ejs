<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Tiger Youth Transport - Premium Cargo Service in Dubai and Gulf Countries. Fast, Reliable, and Professional Logistics.">
    <title>
        <%= title %>
    </title>

    <!-- Favicon -->
    <link rel="icon" href="/img/favicon.svg" type="image/svg+xml">

    <!-- Google Fonts: Inter and Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Outfit:wght@400;600;700;800&display=swap"
        rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <!-- Top Bar -->
    <div class="top-bar">
        <div class="top-bar-container">
            <div class="top-info">
                <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--orange)"
                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                        style="vertical-align: middle; margin-right: 4px;">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                        <polyline points="22,6 12,13 2,6"></polyline>
                    </svg> info@tigeryouthtransport.com</span>
                <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--orange)"
                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                        style="vertical-align: middle; margin-right: 4px;">
                        <path
                            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z">
                        </path>
                    </svg> +971 54 739 2605</span>
            </div>
            <div class="top-location">
                <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--orange)"
                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                        style="vertical-align: middle; margin-right: 4px;">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                    </svg> Dubai | Oman | KSA | Bahrain</span>
            </div>
        </div>
    </div>

    <!-- Header Navigation -->
    <header class="main-header">
        <div class="nav-container">
            <!-- Logo -->
            <a href="/" class="logo">
                <img src="/img/product.svg" alt="Tiger Youth Transport Logo" class="logo-img">
            </a>

            <!-- Mobile Menu Toggle -->
            <button class="mobile-toggle" id="mobileToggle" aria-label="Toggle navigation">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <nav class="main-nav" id="mainNav">
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/about">About Us</a></li>
                    <li><a href="/services">Services</a></li>
                    <li><a href="/team">Team</a></li>
                    <li><a href="/contact">Contact</a></li>
                </ul>
                <a href="/book" class="btn-primary nav-book-btn" style="color: white;">Book Now</a>
            </nav>
        </div>
    </header>

    <main class="content-wrapper">