<%- include('partials/header') %>

    <!-- Page Header -->
    <section class="page-header">
        <div class="container">
            <h1>Meet Our Team</h1>
            <div class="breadcrumb">
                <a href="/">Home</a> / <span>Team</span>
            </div>
        </div>
    </section>

    <!-- Team Section -->
    <section class="section-padding bg-light">
        <div class="container">
            <div class="section-title text-center mb-5">
                <h2 class="animate-up">Professional & Dedicated</h2>
                <p class="animate-up">Our team of logistics experts is committed to providing the highest quality cargo services across Dubai and the Gulf.</p>
            </div>

            <!-- Team Manager Section -->
            <div class="manager-highlight mb-6 animate-up">
                <div class="grid grid-2 align-center">
                    <div class="team-img-wrapper manager-img">
                        <img src="/img/team-manager.png" alt="Team Manager" class="img-fluid radius-image shadow-large">
                    </div>
                    <div class="team-info manager-content">
                        <span class="sub-heading">Leadership</span>
                        <h3>Mohammed Al-Fayed</h3>
                        <p class="team-role">General Manager</p>
                        <p class="mt-3">With over 15 years of experience in the logistics and transport industry in the UAE, Mohammed leads Tiger Youth Transport with a vision of excellence and reliability. He ensures every shipment is handled with the utmost care and reaches its destination on time.</p>
                        <div class="footer-socials mt-4">
                            <a href="#" aria-label="LinkedIn"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg></a>
                            <a href="#" aria-label="Twitter"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg></a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="section-title text-center mb-5 mt-6">
                <h2 class="animate-up">Our Core Team</h2>
            </div>

            <!-- Employees Grid -->
            <div class="grid grid-3">
                <!-- Employee 1 -->
                <div class="team-card animate-up">
                    <div class="team-img-wrapper">
                        <img src="/img/team-employee.png" alt="Ahmed Hassan" class="img-fluid">
                        <div class="team-overlay">
                            <div class="team-socials-overlay">
                                <a href="#"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg></a>
                                <a href="#"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg></a>
                            </div>
                        </div>
                    </div>
                    <div class="team-body">
                        <h3>Ahmed Hassan</h3>
                        <p class="team-role">Senior Logistics Coordinator</p>
                        <p class="team-desc">Expert in route optimization and multi-modal transport solutions across the GCC region.</p>
                    </div>
                </div>

                <!-- Employee 2 -->
                <div class="team-card animate-up">
                    <div class="team-img-wrapper">
                        <img src="/img/team-employee-2.png" alt="Sarah Jenkins" class="img-fluid">
                        <div class="team-overlay">
                            <div class="team-socials-overlay">
                                <a href="#"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg></a>
                                <a href="#"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg></a>
                            </div>
                        </div>
                    </div>
                    <div class="team-body">
                        <h3>Sarah Jenkins</h3>
                        <p class="team-role">Operations Manager</p>
                        <p class="team-desc">Dedicated to streamlining warehouse operations and ensuring inventory accuracy for our clients.</p>
                    </div>
                </div>

                <!-- Employee 3 -->
                <div class="team-card animate-up">
                    <div class="team-img-wrapper">
                        <img src="/img/team-employee-3.png" alt="Zaid Ali" class="img-fluid">
                        <div class="team-overlay">
                            <div class="team-socials-overlay">
                                <a href="#"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg></a>
                                <a href="#"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg></a>
                            </div>
                        </div>
                    </div>
                    <div class="team-body">
                        <h3>Zaid Ali</h3>
                        <p class="team-role">Fleet Supervisor</p>
                        <p class="team-desc">Overseeing our vehicle fleet maintenance and driver safety protocols to ensure reliable delivery.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Join Our Team CTA -->
    <section class="cta-banner text-center">
        <div class="container">
            <h2 class="mb-4">Want to Join Our Team?</h2>
            <p class="mb-5" style="max-width: 600px; margin: 0 auto 30px;">We are always looking for passionate individuals to join our growing logistics network.</p>
            <a href="/contact" class="btn-primary">Contact Us Today</a>
        </div>
    </section>

<%- include('partials/footer') %>
