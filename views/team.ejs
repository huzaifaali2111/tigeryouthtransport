        <p>Expert in route optimization and multi-modal transport solutions across the GCC region.</p>
      </div>

      <!-- Member 2 -->
      <div class="member-card animate-up">
        <div class="member-avatar">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </div>
        <h3>Sarah Jenkins</h3>
        <span class="member-role">Operations Manager</span>
        <p>Dedicated to streamlining warehouse operations and ensuring inventory accuracy for our clients.</p>
      </div>

      <!-- Member 3 -->
      <div class="member-card animate-up">
        <div class="member-avatar">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </div>
        <h3>Zaid Ali</h3>
        <span class="member-role">Fleet Supervisor</span>
        <p>Overseeing vehicle fleet maintenance and driver safety protocols to ensure reliable delivery.</p>
      </div>

    </div>
  </div>
</section>

<!-- CTA Banner (matches site standard .cta-banner) -->
<section class="cta-banner text-center">
  <div class="container">
    <h2 class="mb-4">Want to Join Our Team?</h2>
    <p class="mb-5" style="max-width:560px;margin:0 auto 30px;color:#a0aec0;">
      We are always looking for passionate individuals to join our growing logistics network across the UAE and Gulf.
    </p>
    <a href="/contact" class="btn-primary">Contact Us Today</a>
  </div>
</section>

<%- include('partials/footer') %>