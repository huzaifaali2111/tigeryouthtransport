<%- include('partials/header') %>

<style>
  /* ── Team Page Overrides ── */
  .team-leader-card {
    background: var(--white);
    border-radius: 10px;
    box-shadow: 0 8px 30px rgba(10,25,47,0.09);
    display: flex;
    align-items: center;
    gap: 40px;
    padding: 44px 48px;
    max-width: 820px;
    margin: 0 auto;
    border-left: 5px solid var(--orange);
  }
  .team-avatar {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    background-color: var(--light-grey);
    border: 3px solid var(--orange);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .team-avatar svg {
    width: 62px;
    height: 62px;
    color: var(--navy);
  }
  .team-leader-info .role-badge {
    display: inline-block;
    background-color: var(--orange);
    color: var(--white);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 4px 14px;
    border-radius: 4px;
    margin-bottom: 10px;
  }
  .team-leader-info h3 {
    font-size: 1.6rem;
    color: var(--navy);
    margin-bottom: 10px;
  }
  .team-leader-info p {
    color: var(--grey);
    font-size: 0.97rem;
    line-height: 1.75;
    margin-bottom: 18px;
  }
  .linkedin-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--navy);
    border: 1.5px solid var(--navy);
    padding: 7px 18px;
    border-radius: 4px;
    transition: var(--transition);
  }
  .linkedin-link:hover {
    background: var(--navy);
    color: var(--white);
  }

  /* Member Cards */
  .team-members-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 28px;
  }
  .member-card {
    background: var(--white);
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(10,25,47,0.07);
    padding: 36px 28px 30px;
    text-align: center;
    transition: var(--transition);
    border-top: 4px solid transparent;
  }
  .member-card:hover {
    transform: translateY(-7px);
    box-shadow: 0 12px 35px rgba(10,25,47,0.12);
    border-top-color: var(--orange);
  }
  .member-avatar {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background-color: var(--light-grey);
    border: 2.5px solid #e0e5ef;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    transition: var(--transition);
  }
  .member-card:hover .member-avatar {
    border-color: var(--orange);
    background-color: #fff5ea;
  }
  .member-avatar svg {
    width: 50px;
    height: 50px;
    color: var(--navy);
    transition: var(--transition);
  }
  .member-card:hover .member-avatar svg {
    color: var(--orange);
  }
  .member-card h3 {
    font-size: 1.1rem;
    color: var(--navy);
    margin-bottom: 6px;
  }
  .member-card .member-role {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 12px;
  }
  .member-card p {
    color: var(--grey);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  /* Section subtitle line */
  .section-title-line {
    width: 52px;
    height: 3px;
    background: var(--orange);
    margin: 12px auto 0;
    border-radius: 2px;
  }

  @media (max-width: 700px) {
    .team-leader-card {
      flex-direction: column;
      text-align: center;
      padding: 32px 24px;
      gap: 24px;
    }
  }
</style>

<!-- Page Header (matches site standard) -->
<section class="page-header">
  <div class="container">
    <h1>Meet Our Team</h1>
    <div class="breadcrumb">
      <a href="/">Home</a> / <span>Team</span>
    </div>
  </div>
</section>

<!-- Leadership Section -->
<section class="section-padding">
  <div class="container">
    <div class="section-title text-center mb-5">
      <span class="sub-heading">LEADERSHIP</span>
      <h2>The Person Leading the Way</h2>
      <div class="section-title-line"></div>
    </div>

    <div class="team-leader-card animate-up">
      <!-- Generic person silhouette SVG (no photo) -->
      <div class="team-avatar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
      </div>
      <div class="team-leader-info">
        <div class="role-badge">Sales Manager</div>
        <h3>Shahzaib Ramzan</h3>
        <p>With over 3 years of experience in the logistics and transport industry across the UAE, Shahzaib drives Tiger Youth Transport's sales strategy with a vision of excellence and reliability — ensuring every client partnership is built on trust and measurable results.</p>
        <a href="https://www.linkedin.com/in/shahzaib-ramzan-766519370/" target="_blank" class="linkedin-link">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
          View LinkedIn
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Core Team -->
