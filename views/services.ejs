<%- include('partials/header') %>

<section class="page-header">
    <div class="container">
        <h1>Our Services</h1>
        <p class="breadcrumb"><a href="/">Home</a> / Services</p>
    </div>
</section>

<section class="section-padding bg-light">
    <div class="container">
        <div class="section-title text-center mb-5">
            <h2>Comprehensive <span class="highlight">Cargo Solutions</span></h2>
            <p>Tailored transport services built to meet the unique demands of Gulf region trade.</p>
        </div>

        <div class="grid grid-3">
            <!-- Service 1 -->
            <div class="service-card">
                <div class="service-img" style="background-image: url('https://images.pexels.com/photos/2199293/pexels-photo-2199293.jpeg?auto=compress&cs=tinysrgb&w=800'); background-size: cover; background-position: center;"></div>
                <div class="service-body">
                    <h3>Road Freight</h3>
                    <p>FTL (Full Truckload) and LTL (Less than Truckload) services stretching from the UAE to Saudi Arabia, Oman, Bahrain and Kuwait. Equipped with reefer and flatbed options.</p>
                </div>
            </div>

            <!-- Service 2 -->
            <div class="service-card">
                <div class="service-img" style="background-image: url('https://images.pexels.com/photos/6169668/pexels-photo-6169668.jpeg?auto=compress&cs=tinysrgb&w=800'); background-size: cover; background-position: center;"></div>
                <div class="service-body">
                    <h3>Custom Clearance</h3>
                    <p>Navigating cross-border regulations is complex. We handle all documentation and customs brokering to ensure your shipments are never delayed at checkpoints.</p>
                </div>
            </div>

            <!-- Service 3 -->
            <div class="service-card">
                <div class="service-img" style="background-image: url('https://images.pexels.com/photos/236705/pexels-photo-236705.jpeg?auto=compress&cs=tinysrgb&w=800'); background-size: cover; background-position: center;"></div>
                <div class="service-body">
                    <h3>Warehousing</h3>
                    <p>Short term and long term warehousing solutions located strategically near major ports and highways in Dubai. Fully secured 24/7 with climatic control available.</p>
                </div>
            </div>

            <!-- Service 4 -->
            <div class="service-card">
                <div class="service-img" style="background-image: url('https://images.pexels.com/photos/6169052/pexels-photo-6169052.jpeg?auto=compress&cs=tinysrgb&w=800'); background-size: cover; background-position: center;"></div>
                <div class="service-body">
                    <h3>Heavy & Project Cargo</h3>
                    <p>Oversized freight transport requiring special permits, route surveys, and specialized equipment. Ideal for construction and energy sector clients.</p>
                </div>
            </div>

            <!-- Service 5 -->
            <div class="service-card">
                <div class="service-img" style="background-image: url('https://images.pexels.com/photos/1556691/pexels-photo-1556691.jpeg?auto=compress&cs=tinysrgb&w=800'); background-size: cover; background-position: center;"></div>
                <div class="service-body">
                    <h3>Express Delivery</h3>
                    <p>Time-critical delivery services using our dedicated express vans. Designed for urgent spare parts, sensitive equipment, and high-value fragile goods.</p>
                </div>
            </div>

            <!-- Service 6 -->
            <div class="service-card">
                <div class="service-img" style="background-image: url('https://images.pexels.com/photos/6686455/pexels-photo-6686455.jpeg?auto=compress&cs=tinysrgb&w=800'); background-size: cover; background-position: center;"></div>
                <div class="service-body">
                    <h3>Cold Chain Logistics</h3>
                    <p>Strictly temperature-controlled transportation for perishables, pharmaceuticals, and sensitive goods to protect cargo integrity under the Gulf heat.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FAQ Section -->
<section class="section-padding">
    <div class="container">
        <div class="grid grid-2 align-center">
            <div>
                <img src="https://images.pexels.com/photos/6169051/pexels-photo-6169051.jpeg?auto=compress&cs=tinysrgb&w=1200" alt="Warehouse Operations and Logistics" class="img-fluid radius-image shadow-large">
            </div>
            <div class="faq-accordion">
                <h4 class="sub-heading">FREQUENTLY ASKED QUESTIONS</h4>
                <h2>Logistics <span class="highlight">Simplified</span></h2>
                
                <div class="faq-item mt-4">
                    <h4 class="faq-question">How do you handle cross-border customs?</h4>
                    <p class="faq-answer">We have dedicated customs clearance brokers at all major GCC borders. We manage all documentation, ensuring immediate clearance without unexpected delays.</p>
                </div>
                
                <div class="faq-item mt-3">
                    <h4 class="faq-question">Do you provide cargo insurance?</h4>
                    <p class="faq-answer">Yes, all standard freight shipments come with basic liability coverage, and we offer comprehensive premium insurance for high-value or fragile goods.</p>
                </div>
                
                <div class="faq-item mt-3">
                    <h4 class="faq-question">How fast is express delivery to Riyadh?</h4>
                    <p class="faq-answer">For express shipments via road from Dubai to Riyadh, we ensure a direct, non-stop transit structure allowing delivery within 36 to 48 hours depending on border clearance.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="cta-banner">
    <div class="container text-center">
        <h2>Need a custom logistics plan?</h2>
        <a href="/contact" class="btn-primary mt-3">Speak to an Expert</a>
    </div>
</section>

